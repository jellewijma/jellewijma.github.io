{
  "name": "jellewijma-portfolio",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "npm run optimize:images && npm run build:css",
    "build:css": "tailwindcss -i ./assets/css/tailwind.input.css -o ./assets/css/tailwind.generated.css --minify",
    "deploy:convex": "convex deploy",
    "dev:css": "tailwindcss -i ./assets/css/tailwind.input.css -o ./assets/css/tailwind.generated.css --watch",
    "optimize:images": "node scripts/optimize-images.mjs",
    "check:assets": "node scripts/check-assets.mjs",
    "check": "npm run build:css && npm run check:assets && npm audit --audit-level=moderate",
    "vercel-build": "npm run build"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "convex": "^1.39.1"
  }
}
